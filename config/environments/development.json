{
  "app": {
    "name": "AnimeMultiFlix",
    "environment": "development",
    "debug": true,
    "port": 3000,
    "host": "localhost",
    "apiUrl": "http://localhost:3000/api",
    "frontendUrl": "http://localhost:3000",
    "adminUrl": "http://localhost:3000/admin",
    "wsUrl": "ws://localhost:3001"
  },
  "database": {
    "mongodb": {
      "uri": "mongodb://localhost:27017/anime_multiflix_dev",
      "poolSize": 5
    },
    "redis": {
      "enabled": true,
      "host": "localhost",
      "port": 6379,
      "db": 0,
      "ttl": 300
    }
  },
  "security": {
    "ssl": false,
    "rateLimit": {
      "enabled": false
    },
    "csrf": {
      "enabled": false
    }
  },
  "logging": {
    "level": "DEBUG",
    "console": true,
    "file": false
  },
  "cache": {
    "type": "simple",
    "ttl": 60
  },
  "features": {
    "voiceChat": true,
    "watchParty": true,
    "groups": true,
    "premium": true
  },
  "email": {
    "enabled": false,
    "backend": "console"
  },
  "payment": {
    "enabled": false,
    "testMode": true
  }
}
